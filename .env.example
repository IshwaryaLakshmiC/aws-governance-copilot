# Copy to .env and fill in values
# For local dev with Docker postgres, use these defaults as-is

DB_HOST=localhost
DB_PORT=5432
DB_NAME=cloud_security_platform
DB_USER=platform_admin
DB_PASSWORD=localdev123

AWS_REGION=us-east-1
# AWS credentials come from ~/.aws/credentials or environment
# Needs Bedrock access: aws bedrock list-foundation-models --region us-east-1

OPENROUTER_API_KEY=sk-or-v1-YOUR_KEY_HERE
# Get free key at openrouter.ai — used as Bedrock fallback

# Populated automatically by EC2 userdata from cloud-security-platform-infra
# On EC2: symlinked from /etc/cloud-security-platform.env
DB_HOST=your-rds-endpoint.us-east-1.rds.amazonaws.com
DB_PORT=5432
DB_NAME=cloud_security_platform
DB_USER=platform_admin
DB_PASSWORD=your-password
AWS_REGION=us-east-1
S3_CACHE_BUCKET=cloud-security-platform-app-cache-123456789
OPENROUTER_API_KEY=sk-or-v1-...   # optional fallback
